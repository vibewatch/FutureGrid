# Data snapshot script loads .env / .env.local automatically via @next/env.

# Optional for npm run build:data: enriches occupations with BLS OEWS employment and wage data.
# Register at https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# Optional / future Census collection: required for US Census ABS/BTOS-style API calls.
# Register at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# Optional legacy O*NET Web Services client; current build:data uses the public O*NET zip and does not need this.
# Register at https://services.onetcenter.org/developer/signup
ONET_API_KEY=your_onet_api_key_here
